{
	"name": "celema/log",
	"description": "A simple PSR-3 Logger",
	"type": "library",
	"license": "MIT",
	"authors": [
		{
			"name": "Ernst",
			"email": "ernst@celema.dev"
		}
	],
	"homepage": "https://celema.dev/log",
	"keywords": [
		"celema",
		"log",
		"logging",
		"psr-3"
	],
	"autoload": {
		"psr-4": {
			"Celema\\Log\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Celema\\Log\\Tests\\": "tests/"
		}
	},
	"require": {
		"php": "^8.5",
		"psr/log": "^3.0"
	},
	"require-dev": {
		"celema/dev": "^5.0"
	},
	"scripts": {
		"test": [
			"./vendor/bin/phpunit --testdox --no-coverage --colors=always"
		],
		"types": "./vendor/bin/psalm --no-cache",
		"lint": [
			"./vendor/bin/mago fmt --check",
			"./vendor/bin/mago lint"
		],
		"docs:format": "npx prettier@3.6.2 --write --config ./docs/.prettierrc README.md CHANGELOG.md LICENSE.md docs/",
		"docs:lint": "npx markdownlint-cli2@0.22.1 --config ./vendor/celema/dev/config/markdownlint.jsonc README.md CHANGELOG.md LICENSE.md docs/",
		"coverage:test": "php -d xdebug.mode=coverage ./vendor/bin/phpunit --testdox --path-coverage --colors=always",
		"coverage:analyze": "./vendor/bin/coverlyzer .coverage/coverage.php",
		"coverage": [
			"composer coverage:test",
			"composer coverage:analyze"
		],
		"ci": [
			"composer lint",
			"composer coverage",
			"composer types",
			"composer docs:lint"
		]
	}
}

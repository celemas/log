{
	"name": "celemas/log",
	"description": "A simple PSR-3 Logger",
	"type": "library",
	"license": "MIT",
	"authors": [
		{
			"name": "Ernst",
			"email": "ernst@celemas.dev"
		}
	],
	"homepage": "https://celemas.dev/log",
	"keywords": [
		"celemas",
		"log",
		"logging",
		"psr-3"
	],
	"autoload": {
		"psr-4": {
			"Celemas\\Log\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Celemas\\Log\\Tests\\": "tests/"
		}
	},
	"require": {
		"php": "^8.5",
		"psr/log": "^3.0"
	},
	"require-dev": {
		"celemas/dev": "^3.0"
	},
	"scripts": {
		"test": [
			"./vendor/bin/phpunit --testdox --no-coverage --colors=always"
		],
		"types": "./vendor/bin/psalm --no-cache",
		"lint": [
			"./vendor/bin/mago fmt --check",
			"./vendor/bin/mago lint"
		],
		"mdlint": "markdownlint-cli2 README.md CHANGELOG.md LICENSE.md docs/",
		"coverage": [
			"php -d xdebug.mode=coverage ./vendor/bin/phpunit --testdox --path-coverage --coverage-text --coverage-php=.coverage/cover.php --colors=always",
			"./vendor/bin/coverlyzer .coverage/cover.php"
		],
		"ci": [
			"composer lint",
			"composer coverage",
			"composer types",
			"composer mdlint"
		]
	}
}
